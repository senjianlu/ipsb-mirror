{
  "name": "ipsb-mirror",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:create": "wrangler d1 create ipsb-mirror",
    "db:init": "wrangler d1 execute ipsb-mirror --file=schema.sql",
    "db:init:local": "wrangler d1 execute ipsb-mirror --local --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  }
}
